# =================================
# ZYPHON PLATFORM CONFIGURATION
# =================================

# Database (NeonDB Postgres) - REQUIRED
# Use the pooler URL for serverless (with -pooler in hostname)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Direct URL for migrations (non-pooled, optional)
DIRECT_DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# Redis - REQUIRED for task queue (use Upstash for serverless)
REDIS_URL="redis://default:password@host:6379"

# ─── AI / LLM ───────────────────────────────────────────────

# LLM Provider: "groq" (recommended) or "ollama" (legacy)
LLM_PROVIDER="groq"

# Groq API (default provider)
GROK="gsk_your_api_key_here"
GROQ_MODEL="llama-3.3-70b-versatile"
# GROQ_BASE_URL="https://api.groq.com/openai/v1"  # optional override

# Ollama LLM - LEGACY (only used if LLM_PROVIDER="ollama")
# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="deepseek-coder-v2:16b"

# Timeout for LLM requests (ms, default: 120000)
LLM_TIMEOUT_MS="120000"

# API Configuration (for separate API server)
API_PORT=3002
API_HOST="0.0.0.0"

# Web Configuration
WEB_PORT=3000

# Security
API_KEY_SALT="change-this-to-random-string"
JWT_SECRET="change-this-to-random-string"
# Secret for Vercel Cron job authentication
CRON_SECRET="change-this-to-random-string"

# Workspaces
# On Vercel, this defaults to /tmp/workspaces
WORKSPACE_ROOT="./workspaces"

# SD3 Image Generation Tool (optional)
SD3_SCRIPT_PATH="./tools/sd3/generate.py"
SD3_MODEL_PATH=""

# ─── FEATURE FLAGS ──────────────────────────────────────────

# B2B/Org API features (default: false)
FEATURE_B2B="false"

# Node environment
NODE_ENV="development"
